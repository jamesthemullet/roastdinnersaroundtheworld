---
import BaseLayout from "../layouts/BaseLayout.astro";
import "./league-of-roasts.css";
import "./../layouts/layout.css";
import { Image } from "astro:assets";
import SortPosts from "../components/sortPosts";
import { fetchGraphQL } from "../lib/api.js";
import ALL_POSTS_QUERY from "../lib/graphql/queries/allPosts";
import SINGLE_POST_QUERY from "../lib/graphql/queries/singlePost";
import { PAGE_IDS } from "../lib/pageIds";

const fetchCurrencyRates = async () => {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);
  try {
    const res = await fetch("https://api.exchangerate-api.com/v4/latest/GBP", {
      signal: controller.signal,
    });
    if (!res.ok) {
      throw new Error(`Exchange rate API responded with status ${res.status}`);
    }
    const data = await res.json();
    if (!data?.rates || typeof data.rates !== "object") {
      throw new Error("Exchange rate API returned unexpected response shape");
    }
    return data.rates;
  } catch (error) {
    console.error("Currency fetch failed, falling back to unconverted prices:", error);
    return null;
  } finally {
    clearTimeout(timeout);
  }
};

const fetchPostsAndCurrency = async () => {
  try {
    const [postsResponse, currencyRates] = await Promise.all([
      fetchGraphQL(ALL_POSTS_QUERY),
      fetchCurrencyRates(),
    ]);

    const posts = postsResponse.posts.nodes;

    const postsWithConvertedPrices = posts.map((post) => {
      const { currency, price } = post.customfields || {};
      const convertedPrice = currencyRates?.[currency] ? price / currencyRates[currency] : price;

      return {
        ...post,
        customfields: {
          ...post.customfields,
          convertedPrice,
        },
      };
    });

    return postsWithConvertedPrices;
  } catch (error) {
    console.error("Error fetching posts:", error);
    return [];
  }
};

const [posts, singlePostResult] = await Promise.all([
  fetchPostsAndCurrency(),
  fetchGraphQL(SINGLE_POST_QUERY, { id: PAGE_IDS.LEAGUE_OF_ROASTS }).catch((error) => {
    console.error("Error fetching GraphQL data:", error);
    throw error;
  }),
]);

const singlePost = singlePostResult?.page;
---

<BaseLayout
  pageTitle="League Of Roasts Around The World"
  description={singlePost.seo.opengraphDescription}
  opengraphImage={singlePost.seo.opengraphImage?.sourceUrl}
>
  <Image
    src={singlePost.featuredImage?.node.sourceUrl}
    alt={singlePost.title}
    width={2000}
    height={2000}
    class="featured-image"
  />
  <div class="container">
    <h2>League Of Roasts:</h2>
    <SortPosts posts={posts} client:only="react" />
  </div>
</BaseLayout>
